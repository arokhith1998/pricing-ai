# Pricekeel web environment. Copy to .env.local for local dev (optional).

# Where the FastAPI service lives. Server-side only (never shipped to the
# browser); the UI talks to the API through Next route handlers / server
# components. Local default is http://127.0.0.1:8000 if unset.
PRICEKEEL_API=http://127.0.0.1:8000

# Shared access code that gates the whole demo. If unset, the gate is OFF and
# the app is fully public (fine for local dev). Set this in production.
# PRICEKEEL_ACCESS_CODE=choose-a-strong-code
