# Pricekeel web environment. Copy to .env.local for local dev (optional).

# Where the FastAPI service lives. Server-side only (never shipped to the
# browser); the UI talks to the API through Next route handlers / server
# components. Local default is http://127.0.0.1:8000 if unset.
PRICEKEEL_API=http://127.0.0.1:8000

# --- Lead store + access codes (production) ---------------------------------
# When both are set, leads and access codes use Supabase/Postgres (run
# supabase/schema.sql first). When unset, a dev fallback is used: leads are
# logged to the console and access codes come from PRICEKEEL_ACCESS_CODES below.
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=service-role-key

# Secret used to derive the access cookie. Set a strong value in production.
# PRICEKEEL_SECRET=change-me-to-a-long-random-string

# Dev-only: comma-separated access codes accepted when Supabase is not set.
# PRICEKEEL_ACCESS_CODES=try-pricekeel,partner-acme

# Optional: surfaces a "request access" mailto on the access-code page.
# NEXT_PUBLIC_CONTACT_EMAIL=hello@yourdomain.com
