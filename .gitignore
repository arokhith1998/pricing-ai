# --- Knowledge base (cloned second-brain repos; never commit into product repo) ---
knowledge/
# Same cloned third-party tooling, checked out at repo root.
obsidian-mind/
obsidian-skills/

# --- Second brain: the user's Obsidian vault lives in its OWN private repo
#     (pricing-ai-vault). It sits here on disk but is never tracked by this repo. ---
vault/

# --- Third-party Obsidian skill + commands copied locally (reproducible from knowledge/) ---
.claude/skills/obsidian-second-brain/
.claude/commands/
# Per-machine Claude Code settings (permissions/env) — not shared.
.claude/settings.local.json

# --- Secrets / env ---
.env
.env.*
!.env.example
*.pem
*.key
# Founder-only credential / password notes — must never land in this repo.
*[Pp]assword*.txt
*[Pp]assword*.md
secrets/
# Local panel-run logs (verbatim LLM output; full transcripts live in vault).
panel-*.log

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
dist/
build/
*.egg-info/

# --- Node / Next.js ---
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo

# --- Data / ML artifacts (keep large/sensitive data out of git) ---
*.parquet
*.duckdb
mlruns/
.ipynb_checkpoints/
# Real customer data NEVER gets committed. Synthetic demo data under
# data/synthetic/ is intentionally allowed. Keep the private/ dir tracked
# (via .gitkeep) but ignore everything dropped into it.
data/private/*
!data/private/.gitkeep
!data/synthetic/

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# --- Streamlit secrets (deploy creds; config.toml is committed) ---
.streamlit/secrets.toml

# --- Obsidian per-machine UI state (vault config is otherwise shareable) ---
**/.obsidian/workspace.json
# Downloaded community themes — reproducible, not source.
**/.obsidian/themes/
