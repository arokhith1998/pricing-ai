# Copy to .env (gitignored) and fill in. NEVER commit .env or paste keys into chat.

# --- OpenAI cross-model review (tools/oai_review.py) ---
OPENAI_API_KEY=
# Optional: set to a model you have access to (default gpt-4o)
OPENAI_REVIEW_MODEL=gpt-4o

# --- Anthropic / Claude (product LLM layer: narrative, copilot, CSV mapping) ---
ANTHROPIC_API_KEY=
# Cost-effective default for narration; CSV-mapping can use a smaller model.
ANTHROPIC_MODEL=claude-sonnet-4-6
